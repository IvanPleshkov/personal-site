---
interface Props {
	size?: number;
	class?: string;
}

const { size = 14, class: className = '' } = Astro.props;
---

<svg
	viewBox="0 0 14 14"
	width={size}
	height={size}
	class:list={['node-glyph', className]}
	fill="currentColor"
	aria-hidden="true"
>
	<line x1="7" y1="7" x2="12" y2="2.5" stroke="currentColor" stroke-width="0.8" />
	<line x1="7" y1="7" x2="2" y2="4" stroke="currentColor" stroke-width="0.8" />
	<line x1="7" y1="7" x2="7" y2="12.5" stroke="currentColor" stroke-width="0.8" />
	<circle cx="12" cy="2.5" r="0.9"></circle>
	<circle cx="2" cy="4" r="0.9"></circle>
	<circle cx="7" cy="12.5" r="0.9"></circle>
	<circle cx="7" cy="7" r="2"></circle>
</svg>

<style>
	.node-glyph {
		display: inline-block;
		vertical-align: -0.15em;
	}
</style>
