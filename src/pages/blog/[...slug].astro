---
import { type CollectionEntry, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { getBlogPosts } from '../../lib/blog';

export async function getStaticPaths() {
	const all = await getBlogPosts();
	const ruSlugs = new Set(
		all
			.filter((p) => p.id.endsWith('/ru'))
			.map((p) => p.id.replace(/\/ru$/, '')),
	);
	return all
		.filter((p) => p.id.endsWith('/en'))
		.map((p) => {
			const slug = p.id.replace(/\/en$/, '');
			return {
				params: { slug },
				props: { post: p, slug, hasTranslation: ruSlugs.has(slug) },
			};
		});
}

interface Props {
	post: CollectionEntry<'blog'>;
	slug: string;
	hasTranslation: boolean;
}

const { post, slug, hasTranslation } = Astro.props;
const { Content } = await render(post);
---

<BlogPost {...post.data} slug={slug} lang="en" hasTranslation={hasTranslation}>
	<Content />
</BlogPost>
