---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getBlogPosts } from '../../lib/blog';
import {
	breadcrumbListSchema,
	collectionPageSchema,
	SITE_URL,
} from '../../lib/schema';

const all = await getBlogPosts();
const posts = all
	.filter((p) => p.id.endsWith('/en'))
	.map((p) => ({ post: p, slug: p.id.replace(/\/en$/, '') }))
	.sort((a, b) => b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf());

const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const collection = collectionPageSchema({
	pageUrl,
	name: `Blog — ${SITE_TITLE}`,
	description: 'Notes from Ivan Pleshkov on Rust, GPU, vector search, and graphics.',
});
const breadcrumb = breadcrumbListSchema([
	{ name: 'Home', url: `${SITE_URL}/` },
	{ name: 'Blog', url: pageUrl },
]);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Blog — ${SITE_TITLE}`}
			description="Notes from Ivan Pleshkov on Rust, GPU, vector search, and graphics."
			ogImage="/og/blog.png"
			pageSchema={[collection, breadcrumb]}
			bilingual
		/>
	</head>
	<body>
		<Header />
		<main>
			<p class="eyebrow">
				<span class="num">02</span> Blog
			</p>
			<h1><em>Notes</em>.</h1>
			<p class="lede">
				Long-form thoughts on Rust, GPU, vector search, and the occasional graphics aside.
			</p>

			{
				posts.length === 0 ? (
					<div class="empty">
						<p class="empty-line">[ no posts yet ]</p>
						<p class="empty-hint">First one is on the way.</p>
					</div>
				) : (
					<ol class="posts">
						{posts.map(({ post, slug }) => (
							<li>
								<a href={`/blog/${slug}/`}>
									<span class="date">
										<FormattedDate date={post.data.pubDate} />
									</span>
									<span class="title">{post.data.title}</span>
									<span class="arrow">→</span>
								</a>
								{post.data.description && (
									<p class="excerpt">{post.data.description}</p>
								)}
							</li>
						))}
					</ol>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	.eyebrow {
		font-family: var(--font-mono);
		font-size: 12px;
		text-transform: lowercase;
		letter-spacing: 0.04em;
		color: var(--text-muted);
		margin: 0 0 1.5em;
	}
	.eyebrow .num {
		color: var(--accent);
		margin-right: 0.4em;
	}
	h1 em {
		font-style: italic;
		color: var(--accent);
	}
	.lede {
		font-family: var(--font-display);
		font-size: 1.3rem;
		font-style: italic;
		color: var(--text-muted);
		max-width: 32em;
		margin-bottom: 2.5em;
	}

	.empty {
		border-top: 1px solid var(--text-muted);
		border-bottom: 1px solid var(--rule);
		padding: 3em 0.4em;
		text-align: left;
	}
	.empty-line {
		font-family: var(--font-mono);
		font-size: 14px;
		color: var(--text-subtle);
		margin: 0 0 0.4em;
		letter-spacing: 0.04em;
	}
	.empty-hint {
		font-family: var(--font-display);
		font-style: italic;
		color: var(--text-muted);
		margin: 0;
	}

	.posts {
		list-style: none;
		padding: 0;
		margin: 0;
		border-top: 1px solid var(--text-muted);
	}
	.posts > li {
		border-bottom: 1px solid var(--rule);
		padding: 0;
	}
	.posts a {
		display: grid;
		grid-template-columns: 7em 1fr auto;
		align-items: baseline;
		gap: 1.2em;
		padding: 1em 0.4em 0.4em;
		text-decoration: none;
		color: var(--text);
		transition: padding 0.18s ease;
	}
	.posts a:hover {
		padding-left: 1em;
		background: var(--accent-soft);
	}
	.posts .date {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--text-subtle);
		font-variant-numeric: tabular-nums;
	}
	.posts .title {
		font-family: var(--font-display);
		font-size: 1.25rem;
		color: var(--text);
	}
	.posts a:hover .title {
		color: var(--accent);
	}
	.posts .arrow {
		color: var(--text-muted);
		font-family: var(--font-sans);
	}
	.posts a:hover .arrow {
		color: var(--accent);
	}
	.posts .excerpt {
		margin: 0 0.4em 1em;
		padding-left: 8.2em;
		color: var(--text-muted);
		font-size: 0.95rem;
		max-width: 50em;
	}
	@media (max-width: 540px) {
		.posts a {
			grid-template-columns: 6em 1fr auto;
			font-size: 0.95rem;
		}
		.posts .excerpt {
			padding-left: 0.4em;
		}
	}
</style>
