---
import { SOCIAL_LINKS } from '../consts';
import { getLangFromUrl } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const today = new Date();
const colophon =
	lang === 'ru'
		? 'Newsreader · Inter · JetBrains Mono'
		: 'Newsreader · Inter · JetBrains Mono';
const builtWith = lang === 'ru' ? 'Собрано на Astro' : 'Built with Astro';
---

<footer>
	<div class="inner">
		<div class="row">
			<a class="link" href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer">
				github
			</a>
			<span class="dot">·</span>
			<a class="link" href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener noreferrer">
				linkedin
			</a>
			<span class="dot">·</span>
			<a class="link" href={SOCIAL_LINKS.telegram} target="_blank" rel="noopener noreferrer">
				telegram
			</a>
			<span class="dot">·</span>
			<a class="link" href={`mailto:${SOCIAL_LINKS.email}`}>email</a>
		</div>
		<div class="row meta">
			<span>© {today.getFullYear()} Ivan Pleshkov</span>
			<span class="dot">·</span>
			<span>{builtWith}</span>
			<span class="dot">·</span>
			<span class="set">{colophon}</span>
		</div>
	</div>
</footer>

<style>
	footer {
		border-top: 1px dashed var(--rule);
		margin-top: 4em;
		padding: 2em 1em 4em;
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--text-muted);
	}
	.inner {
		max-width: 920px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 0.6em;
		align-items: flex-start;
	}
	.row {
		display: flex;
		align-items: center;
		gap: 0.6em;
		flex-wrap: wrap;
	}
	.link {
		color: var(--text-muted);
		text-decoration: none;
		text-transform: lowercase;
	}
	.link:hover {
		color: var(--accent);
	}
	.dot {
		color: var(--text-subtle);
	}
	.meta {
		color: var(--text-subtle);
		font-size: 11px;
	}
	.set {
		font-style: normal;
	}
</style>
