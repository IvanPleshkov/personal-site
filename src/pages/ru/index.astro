---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE, SOCIAL_LINKS } from '../../consts';
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={SITE_TITLE} description="Личный сайт Ивана Плешкова." />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">
					<span class="dot-mark"></span>
					Личный сайт
				</p>
				<h1>
					Иван <em>Плешков</em>.
				</h1>
				<p class="tagline">
					Инженер в Qdrant. Тащу GPU-трюки из графических движков в векторный поиск.
				</p>
				<p class="lede">
					Работаю над ядром векторного поиска в <a href="https://qdrant.tech/" target="_blank" rel="noopener noreferrer">Qdrant</a> на Rust.
					До этого двенадцать лет в C++: рендер-движок в Wargaming, VR и компьютерное зрение для авиасимуляторов,
					кроссплатформенная инфраструктура для видеосвязи, научный софт на Delphi. Живу в Магдебурге.
				</p>
			</section>

			<section class="elsewhere">
				<h2>
					<span class="section-num">§</span> Где меня найти
				</h2>
				<ul class="link-list">
					<li>
						<a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer">
							<span class="key">github</span>
							<span class="val">@IvanPleshkov</span>
							<span class="arrow">↗</span>
						</a>
					</li>
					<li>
						<a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener noreferrer">
							<span class="key">linkedin</span>
							<span class="val">ivan-pleshkov</span>
							<span class="arrow">↗</span>
						</a>
					</li>
					<li>
						<a href={SOCIAL_LINKS.telegram} target="_blank" rel="noopener noreferrer">
							<span class="key">telegram</span>
							<span class="val">{SOCIAL_LINKS.telegramHandle}</span>
							<span class="arrow">↗</span>
						</a>
					</li>
					<li>
						<a href={`mailto:${SOCIAL_LINKS.email}`}>
							<span class="key">email</span>
							<span class="val">{SOCIAL_LINKS.email}</span>
							<span class="arrow">→</span>
						</a>
					</li>
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: 1em 0 2em;
	}
	.eyebrow {
		display: flex;
		align-items: center;
		gap: 0.6em;
		font-family: var(--font-mono);
		font-size: 12px;
		text-transform: lowercase;
		letter-spacing: 0.04em;
		color: var(--text-muted);
		margin: 0 0 1.5em;
	}
	.dot-mark {
		display: inline-block;
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 0 4px var(--accent-soft);
	}
	.hero h1 {
		margin: 0 0 0.2em;
	}
	.hero h1 em {
		font-style: italic;
		color: var(--accent);
	}
	.tagline {
		font-family: var(--font-display);
		font-style: italic;
		font-size: 1.4rem;
		color: var(--text-muted);
		margin: 0 0 1.4em;
	}
	.lede {
		font-size: 1.05rem;
		max-width: 36em;
		color: var(--text);
	}

	.elsewhere {
		margin-top: 3em;
	}
	.elsewhere h2 {
		display: flex;
		align-items: baseline;
		gap: 0.5em;
		font-size: 1.5rem;
		margin-top: 0;
		margin-bottom: 1em;
	}
	.section-num {
		font-family: var(--font-mono);
		font-style: normal;
		font-size: 0.85em;
		color: var(--accent);
	}
	.link-list {
		list-style: none;
		padding: 0;
		margin: 0;
		border-top: 1px dashed var(--rule);
	}
	.link-list li {
		border-bottom: 1px dashed var(--rule);
	}
	.link-list a {
		display: grid;
		grid-template-columns: 7em 1fr auto;
		align-items: baseline;
		gap: 1em;
		padding: 0.85em 0.4em;
		font-family: var(--font-mono);
		font-size: 14px;
		text-decoration: none;
		color: var(--text);
		transition: padding 0.18s ease;
	}
	.link-list a:hover {
		padding-left: 1em;
		background: var(--accent-soft);
	}
	.key {
		color: var(--text-subtle);
		text-transform: lowercase;
		letter-spacing: 0.05em;
	}
	.val {
		color: var(--text);
	}
	.arrow {
		color: var(--text-muted);
		font-family: var(--font-sans);
	}
	.link-list a:hover .arrow {
		color: var(--accent);
	}
	@media (max-width: 540px) {
		.link-list a {
			grid-template-columns: 5.5em 1fr auto;
			font-size: 13px;
		}
	}
</style>
