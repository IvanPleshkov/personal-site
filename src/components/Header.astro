---
import { SOCIAL_LINKS } from '../consts';
import { getAlternateLocale, getLangFromUrl, useTranslations } from '../i18n/ui';
import HeaderLink from './HeaderLink.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const homeHref = lang === 'ru' ? '/ru/' : '/';
const aboutHref = lang === 'ru' ? '/ru/about' : '/about';
const blogHref = lang === 'ru' ? '/ru/blog' : '/blog';
const alternate = getAlternateLocale(Astro.url.pathname);
const altLabel = alternate.lang.toUpperCase();
---

<header>
	<div class="bar">
		<a class="brand" href={homeHref}>
			<span class="brand-mark">ip</span>
			<span class="brand-sep">/</span>
			<span class="brand-domain">ivanpleshkov.dev</span>
		</a>
		<nav>
			<HeaderLink href={homeHref}>
				<span class="num">01</span>{t('nav.home')}
			</HeaderLink>
			<HeaderLink href={blogHref}>
				<span class="num">02</span>{t('nav.blog')}
			</HeaderLink>
			<HeaderLink href={aboutHref}>
				<span class="num">03</span>{t('nav.about')}
			</HeaderLink>
		</nav>
		<div class="actions">
			<a class="lang-switch" href={alternate.href} aria-label={t('lang.switch')}>{altLabel}</a>
			<button id="theme-toggle" type="button" aria-label={t('theme.toggle')} class="theme-toggle">
				<svg
					class="icon-sun"
					viewBox="0 0 24 24"
					width="18"
					height="18"
					fill="none"
					stroke="currentColor"
					stroke-width="1.6"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<circle cx="12" cy="12" r="4"></circle>
					<path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
				</svg>
				<svg
					class="icon-moon"
					viewBox="0 0 24 24"
					width="18"
					height="18"
					fill="none"
					stroke="currentColor"
					stroke-width="1.6"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
				</svg>
			</button>
		</div>
	</div>
</header>

<script is:inline>
	(function () {
		const btn = document.getElementById('theme-toggle');
		if (!btn) return;
		btn.addEventListener('click', () => {
			const current = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
			const next = current === 'dark' ? 'light' : 'dark';
			document.documentElement.dataset.theme = next;
			try {
				localStorage.setItem('theme', next);
			} catch {}
		});
	})();
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		background-color: color-mix(in srgb, var(--bg) 92%, transparent);
		backdrop-filter: saturate(140%) blur(8px);
		-webkit-backdrop-filter: saturate(140%) blur(8px);
		border-bottom: 1px solid var(--rule);
	}
	.bar {
		max-width: 920px;
		margin: 0 auto;
		padding: 0.85em 1.25em;
		display: flex;
		align-items: center;
		gap: 1.5em;
		font-family: var(--font-mono);
		font-size: 13px;
	}
	.brand {
		display: inline-flex;
		align-items: baseline;
		gap: 0.5em;
		text-decoration: none;
		color: var(--text);
		font-family: var(--font-mono);
		font-weight: 500;
	}
	.brand-mark {
		font-family: var(--font-display);
		font-style: italic;
		font-weight: 500;
		font-size: 1.4em;
		line-height: 1;
		color: var(--accent);
	}
	.brand-sep {
		color: var(--text-subtle);
	}
	.brand-domain {
		color: var(--text-muted);
		letter-spacing: -0.01em;
	}
	.brand:hover .brand-domain {
		color: var(--text);
	}
	nav {
		display: flex;
		align-items: center;
		gap: 1.4em;
		margin-left: auto;
	}
	nav :global(a) {
		display: inline-flex;
		align-items: baseline;
		gap: 0.45em;
		color: var(--text-muted);
		text-decoration: none;
		text-transform: lowercase;
		letter-spacing: 0.02em;
	}
	nav :global(a:hover) {
		color: var(--text);
	}
	nav :global(a.active) {
		color: var(--text);
	}
	nav :global(a.active) .num {
		color: var(--accent);
	}
	.num {
		font-size: 0.78em;
		color: var(--text-subtle);
		font-variant-numeric: tabular-nums;
	}
	.actions {
		display: flex;
		align-items: center;
		gap: 0.4em;
	}
	.lang-switch {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 28px;
		height: 28px;
		padding: 0 0.5em;
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 500;
		letter-spacing: 0.08em;
		color: var(--text-muted);
		background: transparent;
		border: 1px solid var(--rule);
		border-radius: 4px;
		text-decoration: none;
		transition: all 0.15s ease;
	}
	.lang-switch:hover {
		color: var(--accent);
		border-color: var(--accent);
	}
	.theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		padding: 0;
		background: transparent;
		border: 1px solid var(--rule);
		border-radius: 4px;
		color: var(--text-muted);
		cursor: pointer;
		transition: all 0.15s ease;
	}
	.theme-toggle:hover {
		border-color: var(--accent);
		color: var(--accent);
	}
	.theme-toggle .icon-sun {
		display: none;
	}
	:root[data-theme='dark'] .theme-toggle .icon-sun {
		display: block;
	}
	:root[data-theme='dark'] .theme-toggle .icon-moon {
		display: none;
	}
	@media (max-width: 720px) {
		.bar {
			gap: 0.8em;
			padding: 0.7em 1em;
			font-size: 12px;
		}
		.brand-domain {
			display: none;
		}
		nav {
			gap: 0.9em;
		}
		.num {
			display: none;
		}
	}
</style>
