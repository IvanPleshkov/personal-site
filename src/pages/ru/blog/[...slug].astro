---
import { type CollectionEntry, render } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';
import { getBlogPosts } from '../../../lib/blog';

export async function getStaticPaths() {
	const all = await getBlogPosts();
	const enSlugs = new Set(
		all
			.filter((p) => p.id.endsWith('/en'))
			.map((p) => p.id.replace(/\/en$/, '')),
	);
	return all
		.filter((p) => p.id.endsWith('/ru'))
		.map((p) => {
			const slug = p.id.replace(/\/ru$/, '');
			return {
				params: { slug },
				props: { post: p, slug, hasTranslation: enSlugs.has(slug) },
			};
		});
}

interface Props {
	post: CollectionEntry<'blog'>;
	slug: string;
	hasTranslation: boolean;
}

const { post, slug, hasTranslation } = Astro.props;
const { Content } = await render(post);
---

<BlogPost {...post.data} slug={slug} lang="ru" hasTranslation={hasTranslation}>
	<Content />
</BlogPost>
